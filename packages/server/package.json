    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@webform/common": "workspace:*",
    "acorn": "^8.16.0",
    "astring": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "isolated-vm": "^5.0.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.9.0",
    "morgan": "^1.10.1",
    "mssql": "^12.2.0",
    "mysql2": "^3.18.2",
    "pg": "^8.19.0",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.7.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
